---
import {
  Flower,
  Flower2,
  Leaf,
  Droplets,
  Droplet,
  Sparkles,
  Sprout,
  Sun,
  Feather,
  Wind,
  Heart,
  Hand,
  Waves,
  Star,
} from 'lucide-astro';
import type { IconName } from '../data/content';

interface Props {
  name: IconName;
  size?: number;
  class?: string;
  strokeWidth?: number;
  'aria-hidden'?: boolean;
}

const { name, size = 24, class: className = '', strokeWidth = 1.5 } = Astro.props;

const map: Record<IconName, any> = {
  Flower,
  Flower2,
  Leaf,
  Droplets,
  Droplet,
  Sparkles,
  Sprout,
  Sun,
  Feather,
  Wind,
  Heart,
  Hand,
  Waves,
  Star,
};

const Component = map[name] ?? Sparkles;
---

<Component size={size} class={className} stroke-width={strokeWidth} aria-hidden="true" />
