---
import Icon from './Icon.astro';
import { benefits } from '../data/content';
---

<section id="beneficios" class="relative overflow-hidden py-24 sm:py-32"
  style="background: linear-gradient(180deg, var(--color-sky-light), var(--color-cream));">
  <div class="aura left-1/2 top-0 h-72 w-72 -translate-x-1/2" style="background: var(--color-sky); opacity:.5;"></div>

  <div class="relative mx-auto max-w-7xl px-5 sm:px-8">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="eyebrow justify-center">{benefits.eyebrow}</span>
      <h2 class="mt-4 font-display text-4xl font-semibold leading-tight text-ink sm:text-5xl">
        {benefits.title}
      </h2>
    </div>

    <ul
      class="mt-14 grid grid-cols-1 gap-px overflow-hidden rounded-[var(--radius-soft)] border border-white/60 bg-white/40 shadow-[var(--shadow-card)] backdrop-blur-sm sm:grid-cols-2 lg:grid-cols-3"
      role="list"
    >
      {
        benefits.items.map((item, i) => (
          <li
            class="group flex flex-col gap-3 bg-cream/70 p-8 transition-colors duration-500 hover:bg-cream"
            data-reveal
            data-delay={(i * 0.06).toFixed(2)}
          >
            <span
              class="inline-flex h-12 w-12 items-center justify-center rounded-full text-gold transition-transform duration-500 group-hover:-translate-y-1"
              style="background: linear-gradient(135deg, var(--color-pink-light), var(--color-sky-light));"
            >
              <Icon name={item.icon} size={24} strokeWidth={1.5} />
            </span>
            <h3 class="font-serif text-lg font-medium text-ink">{item.title}</h3>
            <p class="text-sm leading-relaxed text-ink-soft">{item.description}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
